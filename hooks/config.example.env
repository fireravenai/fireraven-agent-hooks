# Copy to config.env and fill in your values:
#   cp config.example.env config.env && chmod 600 config.env

# Required: FireGuard API key (Project Settings -> API in the Fireraven app)
FIRERAVEN_GUARDRAILS_API_KEY=

# Required: FireGuard project ID (Project Settings -> General)
FIRERAVEN_PROJECT_ID=

# Optional: API base URL (default: https://api.fireraven.ai)
# FIRERAVEN_API_URL=https://api.fireraven.ai

# Optional: Guardrail execution mode passed to FireGuard on each check.
#   fast   - lower latency; runs eligible checks in parallel (default)
#   normal - full sequential checks with complete policy/security details
# FIRERAVEN_EXECUTION_MODE=fast

# Optional: HTTP request timeout in seconds (default: 15)
# FIRERAVEN_REQUEST_TIMEOUT_SEC=15

# Optional: Hook behavior when FireGuard cannot be reached (network, timeout, HTTP error).
#   closed - block the agent action (default; recommended for enforcement)
#   open   - allow the action through on transient API failures
# Policy violations and missing credentials always block regardless of this setting.
# FIRERAVEN_FAIL_MODE=closed
