# Copy to config.env and fill in your values:
#   cp config.example.env config.env && chmod 600 config.env

# Required: FireGuard API key (Project Settings -> API in the Fireraven app)
FIRERAVEN_GUARDRAILS_API_KEY=

# Required: FireGuard project ID (Project Settings -> General)
FIRERAVEN_PROJECT_ID=

# Optional: API base URL (default: https://api.fireraven.ai)
# FIRERAVEN_API_URL=https://api.fireraven.ai

# Optional: Guardrail execution mode - "fast" (default) or "normal"
# FIRERAVEN_EXECUTION_MODE=fast

# Optional: HTTP request timeout in seconds (default: 15)
# FIRERAVEN_REQUEST_TIMEOUT_SEC=15
